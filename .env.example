# Застосунок (публічний URL для Better Auth client)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth (серверні секрети — не NEXT_PUBLIC)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Neon Postgres (dev branch)
# DATABASE_URL — pooled (-pooler), DIRECT_URL — direct (міграції)
DATABASE_URL=
DIRECT_URL=

# Seed admin (лише local/CI, не production)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary (Phase 1 — delivery; API secret лише на сервері)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Playwright (опційно — preview URL після deploy)
# PLAYWRIGHT_BASE_URL=http://localhost:3000
