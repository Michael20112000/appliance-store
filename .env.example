# Застосунок (публічний URL для Better Auth client)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth (серверні секрети — не NEXT_PUBLIC)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Neon Postgres (dev branch)
# DATABASE_URL — pooled (-pooler), DIRECT_URL — direct (міграції)
DATABASE_URL=
DIRECT_URL=

# Seed admin (лише local/CI, не production)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary (Phase 1 — delivery; API secret лише на сервері, не NEXT_PUBLIC)
# CLOUDINARY_API_KEY + CLOUDINARY_API_SECRET обовʼязкові для admin upload (POST /api/upload/sign)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Phase 2 seed — comma-separated public IDs (fallback: demo hero image)
# SEED_CLOUDINARY_PUBLIC_IDS=samples/ecommerce/leather-bag-gray

# Local SEO (Phase 2)
# STORE_ADDRESS=м. Львів, вул. Прикладова, 1
# STORE_PHONE=+380000000000

# Pusher Channels (Phase 5 — realtime chat)
# Create app at https://dashboard.pusher.com — enable private channels
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu
# NEXT_PUBLIC_* must match PUSHER_KEY and PUSHER_CLUSTER (client subscribe)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu
# Pusher auth returns 503 when unset; message POST still persists to DB

# Playwright (опційно — preview URL після deploy)
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# --- Production (Vercel) ---
# Обовʼязкові на production (Vercel → Settings → Environment Variables):
#   DATABASE_URL, DIRECT_URL — Neon production branch (pooled + direct)
#   BETTER_AUTH_SECRET — унікальний ≥32 символів (не CI/dev secret)
#   BETTER_AUTH_URL — https://your-domain.com (без trailing slash)
#   NEXT_PUBLIC_APP_URL — той самий origin, що й BETTER_AUTH_URL (D-06-15)
#   NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
#   PUSHER_APP_ID, PUSHER_KEY, PUSHER_SECRET, PUSHER_CLUSTER
#   NEXT_PUBLIC_PUSHER_KEY, NEXT_PUBLIC_PUSHER_CLUSTER (збіг з PUSHER_KEY / PUSHER_CLUSTER)
#
# Заборонено на production (D-06-14):
#   ADMIN_PASSWORD, ADMIN_EMAIL для seed — адмін уже в БД; не додавати seed-креденшали на prod
#
# Приклад production origin (однаковий для обох URL):
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# BETTER_AUTH_URL=https://your-domain.com
